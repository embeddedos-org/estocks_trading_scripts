//@version=5
strategy("VWAP Mean Reversion Strategy", overlay=true,
         default_qty_type=strategy.percent_of_equity, default_qty_value=10,
         initial_capital=100000, commission_type=strategy.commission.percent,
         commission_value=0.1, slippage=1)

// ─── Inputs ───
i_adxLen        = input.int(14, "ADX Length", minval=1, group="Regime Filter", tooltip="ADX lookback for regime classification. Only trades when ADX < threshold (ranging).")
i_adxThresh     = input.float(25.0, "ADX Ranging Threshold (trade below)", step=1.0, group="Regime Filter", tooltip="Only enter trades when ADX is below this value (ranging market).")
i_rsiLen        = input.int(14, "RSI Length", minval=1, group="RSI", tooltip="RSI lookback for overbought/oversold confirmation at VWAP bands.")
i_rsiOB         = input.float(70.0, "RSI Overbought", minval=50.0, group="RSI", tooltip="RSI above this + price at upper VWAP band = short entry.")
i_rsiOS         = input.float(30.0, "RSI Oversold", maxval=50.0, group="RSI", tooltip="RSI below this + price at lower VWAP band = long entry.")
i_entrySD       = input.float(2.0, "Entry Band (σ)", minval=1.0, step=0.5, group="VWAP", tooltip="Enter when price reaches VWAP ± this many standard deviations. 2.0 = ±2σ bands.")
i_exitAtVWAP    = input.bool(true, "Exit at VWAP", group="VWAP", tooltip="When enabled, take profit at VWAP (mean). Otherwise use ATR stop only.")
i_atrLen        = input.int(14, "ATR Length", minval=1, group="Stops", tooltip="ATR lookback for stop loss calculation.")
i_atrMult       = input.float(1.5, "ATR Stop Multiplier", step=0.1, group="Stops", tooltip="Stop distance = ATR × this multiplier. Set at entry, does not trail.")
i_volConfirm    = input.bool(true, "Volume Confirmation", group="Filters", tooltip="Require above-average volume for entry confirmation.")
i_volSmaLen     = input.int(20, "Volume SMA Length", minval=1, group="Filters", tooltip="Lookback for average volume calculation.")
i_volMult       = input.float(1.2, "Volume Multiplier", step=0.1, group="Filters", tooltip="Volume must exceed SMA × this for confirmation.")
i_posSize       = input.float(10.0, "Position Size %", minval=1.0, maxval=100.0, group="Risk", tooltip="Percentage of equity per trade.")
i_useShorts     = input.bool(true, "Allow Short Entries", group="Risk", tooltip="Enable short entries at upper VWAP deviation band.")
i_showDash      = input.bool(true, "Show Dashboard", group="Display", tooltip="Show VWAP distance, ADX, RSI, and position info.")

// ─── VWAP Calculation ───
isNewSession = ta.change(time("D")) != 0
var float cumVol  = 0.0
var float cumTP   = 0.0
var float cumTP2  = 0.0

if isNewSession
    cumVol := 0.0
    cumTP := 0.0
    cumTP2 := 0.0

src = hlc3
cumVol += volume
cumTP += src * volume
cumTP2 += src * src * volume

vwap = cumVol > 0 ? cumTP / cumVol : na
variance = cumVol > 0 ? math.max(cumTP2 / cumVol - vwap * vwap, 0) : 0
sd = math.sqrt(variance)

upperBand = vwap + sd * i_entrySD
lowerBand = vwap - sd * i_entrySD

// ─── ADX Regime Filter ───
[diP, diM, adx] = ta.dmi(i_adxLen, i_adxLen)
isRanging = adx < i_adxThresh

// ─── RSI ───
rsi = ta.rsi(close, i_rsiLen)

// ─── ATR ───
atr = ta.atr(i_atrLen)

// ─── Volume ───
volSma = ta.sma(volume, i_volSmaLen)
volOK = not i_volConfirm or volume > volSma * i_volMult

// ─── Entry Conditions ───
longCondition  = isRanging and close <= lowerBand and rsi < i_rsiOS and volOK
shortCondition = isRanging and close >= upperBand and rsi > i_rsiOB and i_useShorts and volOK

// ─── Position Sizing ───
qty = math.floor((strategy.equity * i_posSize / 100.0) / close)

// ─── Fixed Stop Tracking ───
var float longStopFixed  = na
var float shortStopFixed = na

// ─── Strategy Execution ───
if longCondition and strategy.position_size <= 0
    if strategy.position_size < 0
        strategy.close("Short", comment="Close → VWAP Long")
    strategy.entry("Long", strategy.long, qty=qty, comment="VWAP MR Long")
    longStopFixed := close - atr * i_atrMult

if shortCondition and strategy.position_size >= 0
    if strategy.position_size > 0
        strategy.close("Long", comment="Close → VWAP Short")
    strategy.entry("Short", strategy.short, qty=qty, comment="VWAP MR Short")
    shortStopFixed := close + atr * i_atrMult

// ─── Exits ───
if strategy.position_size > 0 and not na(vwap) and not na(longStopFixed)
    if i_exitAtVWAP
        strategy.exit("VWAP LX", "Long", stop=longStopFixed, limit=vwap, comment="VWAP TP/SL")
    else
        strategy.exit("ATR LX", "Long", stop=longStopFixed, comment="ATR SL")

if strategy.position_size < 0 and not na(vwap) and not na(shortStopFixed)
    if i_exitAtVWAP
        strategy.exit("VWAP SX", "Short", stop=shortStopFixed, limit=vwap, comment="VWAP TP/SL")
    else
        strategy.exit("ATR SX", "Short", stop=shortStopFixed, comment="ATR SL")

// Reset on flat
if strategy.position_size == 0
    longStopFixed := na
    shortStopFixed := na

// ─── Plots ───
plot(vwap, "VWAP", color=color.yellow, linewidth=2)
pUp = plot(upperBand, "VWAP +" + str.tostring(i_entrySD) + "σ", color=color.new(color.red, 30))
pDn = plot(lowerBand, "VWAP -" + str.tostring(i_entrySD) + "σ", color=color.new(color.green, 30))
fill(pUp, pDn, color=color.new(color.blue, 92), title="VWAP Band Fill")

// ─── Entry Markers ───
plotshape(longCondition and strategy.position_size <= 0, "Long", shape.triangleup,
          location.belowbar, color.green, size=size.small, text="VWAP↑")
plotshape(shortCondition and strategy.position_size >= 0, "Short", shape.triangledown,
          location.abovebar, color.red, size=size.small, text="VWAP↓")

// ─── Background ───
bgCol = strategy.position_size > 0 ? color.new(color.green, 93) :
        strategy.position_size < 0 ? color.new(color.red, 93) : na
bgcolor(bgCol, title="Position BG")

// ─── Dashboard ───
if i_showDash and barstate.islast
    var table dash = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80),
                               border_width=1, border_color=color.gray)

    table.cell(dash, 0, 0, "Metric", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, "Value", text_color=color.white, text_size=size.small)

    table.cell(dash, 0, 1, "VWAP", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, str.tostring(vwap, "#.##"), text_color=color.yellow, text_size=size.small)

    distPct = not na(vwap) ? (close - vwap) / vwap * 100 : 0
    table.cell(dash, 0, 2, "Dist %", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(distPct, "#.##") + "%",
         text_color=distPct > 0 ? color.green : color.red, text_size=size.small)

    table.cell(dash, 0, 3, "ADX", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(adx, "#.#"),
         text_color=isRanging ? color.blue : color.orange, text_size=size.small)

    table.cell(dash, 0, 4, "RSI", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(rsi, "#.#"),
         text_color=rsi > i_rsiOB ? color.red : rsi < i_rsiOS ? color.green : color.gray, text_size=size.small)

    posText = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    posCol = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray
    table.cell(dash, 0, 5, "Position", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, posText, text_color=posCol, text_size=size.small)

// ─── Alerts ───
alertcondition(longCondition, title="VWAP MR Long",
     message='{"symbol":"{{ticker}}","action":"buy","price":{{close}},"strategy":"vwap_mr","signal":"vwap_long"}')
alertcondition(shortCondition, title="VWAP MR Short",
     message='{"symbol":"{{ticker}}","action":"sell","price":{{close}},"strategy":"vwap_mr","signal":"vwap_short"}')
