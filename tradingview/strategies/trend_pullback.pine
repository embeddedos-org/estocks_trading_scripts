//@version=5
strategy("Trend Pullback Engine", overlay=true,
         default_qty_type=strategy.percent_of_equity, default_qty_value=10,
         initial_capital=100000, commission_type=strategy.commission.percent,
         commission_value=0.1, slippage=1)

// ─── Inputs ───
i_ema200Len     = input.int(200, "Trend Filter EMA Length", minval=50, group="Trend Filter", tooltip="Long-term trend filter. Only long above, only short below this EMA.")
i_ema20Len      = input.int(20, "Pullback EMA Length", minval=5, group="Pullback", tooltip="Pullback target EMA. Entry triggers when price pulls back to this level.")
i_rsiLen        = input.int(14, "RSI Length", minval=1, group="Pullback", tooltip="RSI lookback for oversold/overbought confirmation on pullbacks.")
i_rsiThreshLong = input.float(40.0, "RSI Oversold Threshold (Long)", maxval=50.0, group="Pullback", tooltip="RSI must be below this for long pullback entries. Lower = stricter filter.")
i_rsiThreshShort = input.float(60.0, "RSI Overbought Threshold (Short)", minval=50.0, group="Pullback", tooltip="RSI must be above this for short pullback entries. Higher = stricter filter.")
i_atrLen        = input.int(14, "ATR Length", minval=1, group="Stops", tooltip="ATR lookback for stop loss and target calculation.")
i_atrMult       = input.float(1.5, "ATR Stop Multiplier", minval=0.5, step=0.1, group="Stops", tooltip="Fallback stop = ATR × this if swing low/high is too close.")
i_rrRatio       = input.float(2.0, "R:R Target Ratio", minval=1.0, step=0.5, group="Stops", tooltip="Target = entry + (risk × this ratio). 2.0 = 2:1 reward-to-risk.")
i_swingLookback = input.int(10, "Swing Low/High Lookback", minval=3, group="Stops", tooltip="Bars to look back for swing low (long stop) or swing high (short stop).")
i_volConfirm    = input.bool(true, "Require Volume Confirmation", group="Filters", tooltip="Require above-average volume on the pullback entry bar.")
i_volSmaLen     = input.int(20, "Volume SMA Length", minval=1, group="Filters", tooltip="Lookback for average volume calculation.")
i_volMult       = input.float(1.2, "Volume Multiplier", minval=1.0, step=0.1, group="Filters", tooltip="Volume must exceed SMA × this for confirmation.")
i_posSize       = input.float(10.0, "Position Size %", minval=1.0, maxval=100.0, group="Risk", tooltip="Percentage of equity allocated per trade.")
i_useShorts     = input.bool(true, "Allow Short Entries", group="Risk", tooltip="Enable short entries on pullbacks in downtrends.")
i_showDash      = input.bool(true, "Show Dashboard", group="Display", tooltip="Show trend direction, RSI, distance to 20 EMA, and position status.")

// ─── Calculations ───
ema200 = ta.ema(close, i_ema200Len)
ema20  = ta.ema(close, i_ema20Len)
rsi    = ta.rsi(close, i_rsiLen)
atr    = ta.atr(i_atrLen)

volSma = ta.sma(volume, i_volSmaLen)
volOK  = not i_volConfirm or volume > volSma * i_volMult

swingLow  = ta.lowest(low, i_swingLookback)
swingHigh = ta.highest(high, i_swingLookback)

// ─── Trend Direction ───
bullTrend = close > ema200
bearTrend = close < ema200

// ─── Pullback Detection ───
// Long: price pulls back to 20 EMA (close touches or crosses above) in uptrend
pullbackLong = bullTrend and
     (low <= ema20 and close > ema20) and
     rsi < i_rsiThreshLong and
     volOK

// Short: price pulls back up to 20 EMA in downtrend
pullbackShort = bearTrend and i_useShorts and
     (high >= ema20 and close < ema20) and
     rsi > i_rsiThreshShort and
     volOK

// ─── Position Sizing ───
qty = math.floor((strategy.equity * i_posSize / 100.0) / close)

// ─── Stop and Target Calculation ───
var float longStop   = na
var float longTarget = na
var float shortStop  = na
var float shortTarget = na

// ─── Strategy Execution ───
if pullbackLong and strategy.position_size <= 0
    if strategy.position_size < 0
        strategy.close("Short", comment="Close Short → Pullback Long")

    stopLevel = math.min(swingLow, close - atr * i_atrMult)
    riskPerShare = close - stopLevel
    targetLevel = close + riskPerShare * i_rrRatio

    strategy.entry("Long", strategy.long, qty=qty, comment="Pullback Long")
    longStop := stopLevel
    longTarget := targetLevel

if pullbackShort and strategy.position_size >= 0
    if strategy.position_size > 0
        strategy.close("Long", comment="Close Long → Pullback Short")

    stopLevel = math.max(swingHigh, close + atr * i_atrMult)
    riskPerShare = stopLevel - close
    targetLevel = close - riskPerShare * i_rrRatio

    strategy.entry("Short", strategy.short, qty=qty, comment="Pullback Short")
    shortStop := stopLevel
    shortTarget := targetLevel

// ─── Exits ───
if strategy.position_size > 0 and not na(longStop) and not na(longTarget)
    strategy.exit("PB Long Exit", "Long", stop=longStop, limit=longTarget, comment="TP/SL")

if strategy.position_size < 0 and not na(shortStop) and not na(shortTarget)
    strategy.exit("PB Short Exit", "Short", stop=shortStop, limit=shortTarget, comment="TP/SL")

// Trend reversal forced exit
if strategy.position_size > 0 and close < ema200
    strategy.close("Long", comment="Trend Reversal Exit")

if strategy.position_size < 0 and close > ema200
    strategy.close("Short", comment="Trend Reversal Exit")

// Reset on flat
if strategy.position_size == 0
    longStop := na
    longTarget := na
    shortStop := na
    shortTarget := na

// ─── Plots ───
plot(ema200, "200 EMA", color=color.white, linewidth=2)
plot(ema20, "20 EMA", color=color.new(color.yellow, 0), linewidth=2)

plot(longStop, "Long Stop", color=color.red, style=plot.style_linebr, linewidth=1)
plot(longTarget, "Long Target", color=color.green, style=plot.style_linebr, linewidth=1)
plot(shortStop, "Short Stop", color=color.red, style=plot.style_linebr, linewidth=1)
plot(shortTarget, "Short Target", color=color.green, style=plot.style_linebr, linewidth=1)

// ─── Entry Markers ───
plotshape(pullbackLong and strategy.position_size <= 0, "PB Long", shape.triangleup,
          location.belowbar, color.green, size=size.small, text="PB↑")
plotshape(pullbackShort and strategy.position_size >= 0, "PB Short", shape.triangledown,
          location.abovebar, color.red, size=size.small, text="PB↓")

// ─── Trend Background ───
bgcolor(bullTrend ? color.new(color.green, 95) : bearTrend ? color.new(color.red, 95) : na, title="Trend BG")

// ─── Dashboard ───
if i_showDash and barstate.islast
    var table dash = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80),
                               border_width=1, border_color=color.gray)

    table.cell(dash, 0, 0, "Metric", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, "Value", text_color=color.white, text_size=size.small)

    trendText = bullTrend ? "BULLISH" : bearTrend ? "BEARISH" : "NEUTRAL"
    trendCol = bullTrend ? color.green : bearTrend ? color.red : color.gray
    table.cell(dash, 0, 1, "Trend", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, trendText, text_color=trendCol, text_size=size.small)

    table.cell(dash, 0, 2, "RSI", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(rsi, "#.#"), text_color=color.aqua, text_size=size.small)

    table.cell(dash, 0, 3, "Dist to 20 EMA", text_color=color.white, text_size=size.small)
    distPct = (close - ema20) / ema20 * 100
    table.cell(dash, 1, 3, str.tostring(distPct, "#.##") + "%", text_color=color.aqua, text_size=size.small)

    posText = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    posCol = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray
    table.cell(dash, 0, 4, "Position", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, posText, text_color=posCol, text_size=size.small)

// ─── Alerts ───
alertcondition(pullbackLong, title="Pullback Long",
     message='{"symbol":"{{ticker}}","action":"buy","price":{{close}},"strategy":"trend_pullback","signal":"pullback_long"}')
alertcondition(pullbackShort, title="Pullback Short",
     message='{"symbol":"{{ticker}}","action":"sell","price":{{close}},"strategy":"trend_pullback","signal":"pullback_short"}')
