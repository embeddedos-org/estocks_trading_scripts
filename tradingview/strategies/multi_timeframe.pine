//@version=5
strategy("Multi-Timeframe Trend Strategy", overlay=true, default_qty_type=strategy.percent_of_equity,
         default_qty_value=10, initial_capital=100000, commission_type=strategy.commission.percent,
         commission_value=0.1, slippage=1)

// ─── Input Parameters ───
i_htfTimeframe  = input.timeframe("D", "Higher Timeframe")
i_emaFastLen    = input.int(50, "HTF Fast EMA Length", minval=1)
i_emaSlowLen    = input.int(200, "HTF Slow EMA Length", minval=1)
i_macdFast      = input.int(12, "MACD Fast Length", minval=1)
i_macdSlow      = input.int(26, "MACD Slow Length", minval=1)
i_macdSignal    = input.int(9, "MACD Signal Length", minval=1)
i_swingLookback = input.int(10, "Swing High/Low Lookback", minval=1)
i_rrRatio       = input.float(2.0, "Risk-Reward Ratio", minval=0.5, step=0.5)
i_posSize       = input.float(10.0, "Position Size (% of Equity)", minval=1.0, maxval=100.0, step=1.0)

// ─── Higher Timeframe Trend (EMA Crossover) ───
htfEmaFast = request.security(syminfo.tickerid, i_htfTimeframe, ta.ema(close, i_emaFastLen), lookahead=barmerge.lookahead_off)
htfEmaSlow = request.security(syminfo.tickerid, i_htfTimeframe, ta.ema(close, i_emaSlowLen), lookahead=barmerge.lookahead_off)

htfBullish = htfEmaFast > htfEmaSlow
htfBearish = htfEmaFast < htfEmaSlow

// ─── Lower Timeframe MACD ───
[macdLine, signalLine, histLine] = ta.macd(close, i_macdFast, i_macdSlow, i_macdSignal)

macdBullCross = ta.crossover(macdLine, signalLine)
macdBearCross = ta.crossunder(macdLine, signalLine)

// ─── Swing High / Low for Stop Loss ───
swingLow  = ta.lowest(low, i_swingLookback)
swingHigh = ta.highest(high, i_swingLookback)

// ─── Entry Conditions ───
longCondition  = htfBullish and macdBullCross
shortCondition = htfBearish and macdBearCross

// ─── Position Sizing ───
qty = math.floor((strategy.equity * i_posSize / 100.0) / close)

// ─── Calculate Stop Loss and Take Profit ───
var float longSL  = na
var float longTP  = na
var float shortSL = na
var float shortTP = na

if longCondition and strategy.position_size <= 0
    longSL := swingLow
    riskAmount = close - longSL
    longTP := close + riskAmount * i_rrRatio
    if strategy.position_size < 0
        strategy.close("Short", comment="Close Short → Long")
    strategy.entry("Long", strategy.long, qty=qty, comment="MTF Long")
    strategy.exit("Long TP/SL", "Long", stop=longSL, limit=longTP, comment="Long Exit")

if shortCondition and strategy.position_size >= 0
    shortSL := swingHigh
    riskAmount = shortSL - close
    shortTP := close - riskAmount * i_rrRatio
    if strategy.position_size > 0
        strategy.close("Long", comment="Close Long → Short")
    strategy.entry("Short", strategy.short, qty=qty, comment="MTF Short")
    strategy.exit("Short TP/SL", "Short", stop=shortSL, limit=shortTP, comment="Short Exit")

// ─── Plot HTF EMAs ───
plot(htfEmaFast, "HTF EMA Fast", color=color.new(color.blue, 0), linewidth=2)
plot(htfEmaSlow, "HTF EMA Slow", color=color.new(color.orange, 0), linewidth=2)

// ─── Plot Stop / TP levels ───
plot(strategy.position_size > 0 ? longSL : na, "Long Stop Loss", color=color.new(color.red, 0),
     style=plot.style_linebr, linewidth=1)
plot(strategy.position_size > 0 ? longTP : na, "Long Take Profit", color=color.new(color.green, 0),
     style=plot.style_linebr, linewidth=1)
plot(strategy.position_size < 0 ? shortSL : na, "Short Stop Loss", color=color.new(color.red, 0),
     style=plot.style_linebr, linewidth=1)
plot(strategy.position_size < 0 ? shortTP : na, "Short Take Profit", color=color.new(color.green, 0),
     style=plot.style_linebr, linewidth=1)

// ─── Entry / Exit Markers ───
plotshape(longCondition and strategy.position_size <= 0, title="Long Signal",
          style=shape.triangleup, location=location.belowbar,
          color=color.green, size=size.small, text="Long")

plotshape(shortCondition and strategy.position_size >= 0, title="Short Signal",
          style=shape.triangledown, location=location.abovebar,
          color=color.red, size=size.small, text="Short")

// ─── MACD Histogram Subplot ───
// Note: MACD is plotted on the main chart via color-coded bars
histColor = histLine >= 0 ? (histLine > histLine[1] ? color.green : color.lime) :
            (histLine < histLine[1] ? color.red : color.orange)
barcolor(histColor, title="MACD Histogram Bar Color")

// ─── HTF Trend Background ───
bgColor = htfBullish ? color.new(color.green, 93) : htfBearish ? color.new(color.red, 93) : na
bgcolor(bgColor, title="HTF Trend Background")

// ─── Info Table ───
var table infoTable = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 80),
                                 border_width=1, border_color=color.gray)

if barstate.islast
    table.cell(infoTable, 0, 0, "HTF Trend", text_color=color.white, text_size=size.small)
    trendText = htfBullish ? "BULLISH" : htfBearish ? "BEARISH" : "NEUTRAL"
    trendColor = htfBullish ? color.green : htfBearish ? color.red : color.gray
    table.cell(infoTable, 1, 0, trendText, text_color=trendColor, text_size=size.small)

    table.cell(infoTable, 0, 1, "MACD", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 1, str.tostring(macdLine, "#.####"),
               text_color=macdLine > signalLine ? color.green : color.red, text_size=size.small)

    table.cell(infoTable, 0, 2, "Signal", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(signalLine, "#.####"), text_color=color.aqua, text_size=size.small)

    table.cell(infoTable, 0, 3, "Position", text_color=color.white, text_size=size.small)
    posText = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    posColor = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray
    table.cell(infoTable, 1, 3, posText, text_color=posColor, text_size=size.small)

// ─── Alerts ───
alertcondition(longCondition, title="MTF Long Signal", message="MTF Strategy: Long entry on {{ticker}} — HTF bullish + MACD cross")
alertcondition(shortCondition, title="MTF Short Signal", message="MTF Strategy: Short entry on {{ticker}} — HTF bearish + MACD cross")
