//@version=5
strategy("Volatility Squeeze Breakout", overlay=true,
         default_qty_type=strategy.percent_of_equity, default_qty_value=10,
         initial_capital=100000, commission_type=strategy.commission.percent,
         commission_value=0.1, slippage=1)

// ─── Inputs ───
i_bbLen         = input.int(20, "BB Length", minval=1, group="Bollinger Bands", tooltip="Bollinger Bands lookback. BB narrows inside KC = squeeze (compression).")
i_bbDev         = input.float(2.0, "BB Deviation", step=0.1, group="Bollinger Bands", tooltip="BB standard deviation multiplier. Controls band width.")
i_kcLen         = input.int(20, "Keltner Channel Length", minval=1, group="Keltner Channel", tooltip="Keltner Channel EMA lookback. KC acts as the outer envelope for squeeze detection.")
i_kcMult        = input.float(1.5, "KC ATR Multiplier", step=0.1, group="Keltner Channel", tooltip="KC width = EMA ± ATR × this. Lower = tighter KC = squeeze fires more often.")
i_momLen        = input.int(12, "Momentum Length", minval=1, group="Momentum", tooltip="Linear regression momentum lookback. Determines breakout direction when squeeze fires.")
i_atrLen        = input.int(14, "ATR Length (Trailing Stop)", minval=1, group="Stops", tooltip="ATR period for trailing stop calculation after entry.")
i_atrMult       = input.float(2.0, "ATR Trailing Multiplier", step=0.1, group="Stops", tooltip="Trailing stop = price ± ATR × this. Higher = wider stop, more room for moves.")
i_volConfirm    = input.bool(true, "Require Volume Confirmation", group="Filters", tooltip="When enabled, entry requires volume > SMA × multiplier for confirmation.")
i_volSmaLen     = input.int(20, "Volume SMA Length", minval=1, group="Filters", tooltip="Lookback for average volume calculation used in volume filter.")
i_volMult       = input.float(1.3, "Volume Multiplier", step=0.1, group="Filters", tooltip="Volume must exceed SMA × this to confirm breakout. Higher = stricter filter.")
i_posSize       = input.float(10.0, "Position Size %", minval=1.0, maxval=100.0, group="Risk", tooltip="Percentage of equity allocated per trade.")
i_useShorts     = input.bool(true, "Allow Short Entries", group="Risk", tooltip="Enable short entries on bearish squeeze breakouts.")
i_showDash      = input.bool(true, "Show Dashboard", group="Display", tooltip="Show squeeze state, momentum direction, BB width, and position info.")
i_showSqueeze   = input.bool(true, "Show Squeeze Dots", group="Display", tooltip="Red dots = squeeze on. Green/lime dots = squeeze off with momentum direction.")

// ─── Bollinger Bands ───
bbBasis = ta.sma(close, i_bbLen)
bbStd   = ta.stdev(close, i_bbLen)
bbUpper = bbBasis + bbStd * i_bbDev
bbLower = bbBasis - bbStd * i_bbDev

// ─── Keltner Channel ───
kcBasis = ta.ema(close, i_kcLen)
kcAtr   = ta.atr(i_kcLen)
kcUpper = kcBasis + kcAtr * i_kcMult
kcLower = kcBasis - kcAtr * i_kcMult

// ─── Squeeze Detection ───
// Squeeze is ON when BB is INSIDE KC (compression)
squeezeOn  = bbLower > kcLower and bbUpper < kcUpper
squeezeOff = not squeezeOn
squeezeFired = squeezeOff and squeezeOn[1]

// ─── Momentum (linear regression value) ───
mom = ta.linreg(close - math.avg(ta.highest(high, i_momLen), ta.lowest(low, i_momLen)), i_momLen, 0)
momUp   = mom > 0
momDown = mom < 0
momIncreasing = mom > mom[1]
momDecreasing = mom < mom[1]

// ─── Volume Confirmation ───
volSma = ta.sma(volume, i_volSmaLen)
volOK  = not i_volConfirm or volume > volSma * i_volMult

// ─── ATR for Trailing Stop ───
atr = ta.atr(i_atrLen)

// ─── Entry Conditions ───
longCondition  = squeezeFired and momUp and volOK
shortCondition = squeezeFired and momDown and i_useShorts and volOK

// ─── Position Sizing ───
qty = math.floor((strategy.equity * i_posSize / 100.0) / close)

// ─── Trailing Stop ───
var float trailLong  = na
var float trailShort = na

if strategy.position_size > 0
    newStop = close - atr * i_atrMult
    trailLong := math.max(nz(trailLong[1], newStop), newStop)
else
    trailLong := na

if strategy.position_size < 0
    newStop = close + atr * i_atrMult
    trailShort := math.min(nz(trailShort[1], newStop), newStop)
else
    trailShort := na

// ─── Strategy Execution ───
if longCondition and strategy.position_size <= 0
    if strategy.position_size < 0
        strategy.close("Short", comment="Close → Squeeze Long")
    strategy.entry("Long", strategy.long, qty=qty, comment="Squeeze Breakout Long")
    trailLong := close - atr * i_atrMult

if shortCondition and strategy.position_size >= 0
    if strategy.position_size > 0
        strategy.close("Long", comment="Close → Squeeze Short")
    strategy.entry("Short", strategy.short, qty=qty, comment="Squeeze Breakout Short")
    trailShort := close + atr * i_atrMult

// ─── Trailing Stop Exits ───
if strategy.position_size > 0 and not na(trailLong)
    strategy.exit("Squeeze LX", "Long", stop=trailLong, comment="Trail Stop")

if strategy.position_size < 0 and not na(trailShort)
    strategy.exit("Squeeze SX", "Short", stop=trailShort, comment="Trail Stop")

// ─── Plots ───
pBBUp = plot(bbUpper, "BB Upper", color=color.new(color.blue, 30), linewidth=1)
pBBLo = plot(bbLower, "BB Lower", color=color.new(color.blue, 30), linewidth=1)
pKCUp = plot(kcUpper, "KC Upper", color=color.new(color.orange, 30), linewidth=1)
pKCLo = plot(kcLower, "KC Lower", color=color.new(color.orange, 30), linewidth=1)
plot(bbBasis, "Basis", color=color.gray, linewidth=1)

fill(pBBUp, pKCUp, color=squeezeOn ? color.new(color.yellow, 85) : color.new(color.green, 95), title="Upper Fill")
fill(pBBLo, pKCLo, color=squeezeOn ? color.new(color.yellow, 85) : color.new(color.green, 95), title="Lower Fill")

plot(trailLong, "Trail Long", color=color.green, style=plot.style_linebr, linewidth=2)
plot(trailShort, "Trail Short", color=color.red, style=plot.style_linebr, linewidth=2)

// ─── Squeeze Indicator Dots ───
plotshape(i_showSqueeze and squeezeOn, "Squeeze On", shape.circle, location.bottom, color.red, size=size.tiny)
plotshape(i_showSqueeze and squeezeOff and momUp, "Squeeze Off ↑", shape.circle, location.bottom,
          color=momIncreasing ? color.lime : color.green, size=size.tiny)
plotshape(i_showSqueeze and squeezeOff and momDown, "Squeeze Off ↓", shape.circle, location.bottom,
          color=momDecreasing ? color.maroon : color.red, size=size.tiny)

// ─── Entry Markers ───
plotshape(longCondition and strategy.position_size <= 0, "Long Entry", shape.triangleup,
          location.belowbar, color.lime, size=size.small, text="SQ↑")
plotshape(shortCondition and strategy.position_size >= 0, "Short Entry", shape.triangledown,
          location.abovebar, color.fuchsia, size=size.small, text="SQ↓")

// ─── Background ───
bgcolor(squeezeOn ? color.new(color.yellow, 93) : na, title="Squeeze BG")

// ─── Dashboard ───
if i_showDash and barstate.islast
    var table dash = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80),
                               border_width=1, border_color=color.gray)

    table.cell(dash, 0, 0, "Metric", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, "Value", text_color=color.white, text_size=size.small)

    sqText = squeezeOn ? "SQUEEZE" : "RELEASED"
    sqCol = squeezeOn ? color.red : color.green
    table.cell(dash, 0, 1, "State", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, sqText, text_color=sqCol, text_size=size.small)

    momText = momUp ? "BULLISH" : "BEARISH"
    momCol = momUp ? color.green : color.red
    table.cell(dash, 0, 2, "Momentum", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, momText + " (" + str.tostring(mom, "#.##") + ")", text_color=momCol, text_size=size.small)

    bbW = (bbUpper - bbLower) / bbBasis * 100
    table.cell(dash, 0, 3, "BB Width %", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(bbW, "#.##"), text_color=color.aqua, text_size=size.small)

    posText = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    posCol = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray
    table.cell(dash, 0, 4, "Position", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, posText, text_color=posCol, text_size=size.small)

// ─── Alerts ───
alertcondition(longCondition, title="Squeeze Long",
     message='{"symbol":"{{ticker}}","action":"buy","price":{{close}},"strategy":"vol_breakout","signal":"squeeze_long"}')
alertcondition(shortCondition, title="Squeeze Short",
     message='{"symbol":"{{ticker}}","action":"sell","price":{{close}},"strategy":"vol_breakout","signal":"squeeze_short"}')
alertcondition(squeezeFired, title="Squeeze Fired",
     message='{"symbol":"{{ticker}}","strategy":"vol_breakout","signal":"squeeze_fired","price":{{close}}}')
