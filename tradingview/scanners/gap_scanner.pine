//@version=5
indicator("Gap Scanner", overlay=true, max_labels_count=500, max_boxes_count=500)

// ─── Input Parameters ───
i_gapThreshold  = input.float(1.0, "Gap Threshold %", minval=0.1, step=0.1)
i_volAvgLen     = input.int(20, "Volume Average Length", minval=1)
i_trendLen      = input.int(50, "Trend Length (for classification)", minval=10)
i_extendedBars  = input.int(10, "Extended Move Bars (for exhaustion)", minval=3)
i_showTable     = input.bool(true, "Show Gap Table")
i_maxGaps       = input.int(10, "Max Gaps in Table", minval=1, maxval=20)
i_fillTrackBars = input.int(50, "Gap Fill Tracking Bars", minval=10, maxval=200)
i_bullColor     = input.color(color.green, "Gap Up Color")
i_bearColor     = input.color(color.red, "Gap Down Color")

// ─── Previous Day Values ───
prevHigh  = high[1]
prevLow   = low[1]
prevClose = close[1]

// ─── Gap Detection ───
gapUp     = open > prevHigh
gapDown   = open < prevLow
gapUpPct  = gapUp ? (open - prevHigh) / prevHigh * 100 : 0.0
gapDownPct = gapDown ? (prevLow - open) / prevLow * 100 : 0.0

isGapUp   = gapUp and gapUpPct >= i_gapThreshold
isGapDown = gapDown and gapDownPct >= i_gapThreshold
isGap     = isGapUp or isGapDown

// ─── Volume Analysis ───
volAvg      = ta.sma(volume, i_volAvgLen)
volRatio    = volume / math.max(volAvg, 1)
highVolume  = volRatio > 1.5

// ─── Trend Detection for Classification ───
trendSma    = ta.sma(close, i_trendLen)
inUptrend   = close > trendSma
inDowntrend = close < trendSma

// ─── Extended Move Detection ───
consecutiveUp   = 0
consecutiveDown = 0
for i = 1 to i_extendedBars
    if close[i] > close[i + 1]
        consecutiveUp += 1
    if close[i] < close[i + 1]
        consecutiveDown += 1

extendedUp   = consecutiveUp >= math.round(i_extendedBars * 0.7)
extendedDown = consecutiveDown >= math.round(i_extendedBars * 0.7)

// ─── Gap Classification ───
// Common: likely to fill same day
// Breakaway: high volume + in trend direction
// Exhaustion: after extended move in same direction
var string gapType = ""

if isGapUp
    if extendedUp
        gapType := "Exhaustion"
    else if highVolume and inUptrend
        gapType := "Breakaway"
    else
        gapType := "Common"

if isGapDown
    if extendedDown
        gapType := "Exhaustion"
    else if highVolume and inDowntrend
        gapType := "Breakaway"
    else
        gapType := "Common"

// ─── Gap Fill Tracking ───
var float gapUpLevel   = na
var float gapDownLevel = na
var bool  gapUpFilled  = false
var bool  gapDownFilled = false
var int   gapUpBar     = na
var int   gapDownBar   = na

if isGapUp
    gapUpLevel  := prevHigh
    gapUpFilled := false
    gapUpBar    := bar_index

if isGapDown
    gapDownLevel  := prevLow
    gapDownFilled := false
    gapDownBar    := bar_index

// Check if gap gets filled
gapUpJustFilled  = false
gapDownJustFilled = false

if not na(gapUpLevel) and not gapUpFilled and low <= gapUpLevel
    gapUpFilled     := true
    gapUpJustFilled := true

if not na(gapDownLevel) and not gapDownFilled and high >= gapDownLevel
    gapDownFilled     := true
    gapDownJustFilled := true

// ─── Store Gap History for Table ───
var float[] gapPrices    = array.new_float(0)
var float[] gapPcts      = array.new_float(0)
var int[]   gapDirs      = array.new_int(0)     // 1 = up, -1 = down
var int[]   gapTypes     = array.new_int(0)     // 0 = common, 1 = breakaway, 2 = exhaustion
var int[]   gapFilled    = array.new_int(0)     // 0 = no, 1 = yes
var int[]   gapBars      = array.new_int(0)

if isGap
    typeCode = gapType == "Breakaway" ? 1 : gapType == "Exhaustion" ? 2 : 0

    array.unshift(gapPrices, open)
    array.unshift(gapPcts, isGapUp ? gapUpPct : gapDownPct)
    array.unshift(gapDirs, isGapUp ? 1 : -1)
    array.unshift(gapTypes, typeCode)
    array.unshift(gapFilled, 0)
    array.unshift(gapBars, bar_index)

    if array.size(gapPrices) > i_maxGaps
        array.pop(gapPrices)
        array.pop(gapPcts)
        array.pop(gapDirs)
        array.pop(gapTypes)
        array.pop(gapFilled)
        array.pop(gapBars)

// Update fill status in history
if array.size(gapFilled) > 0
    for i = 0 to math.min(array.size(gapFilled) - 1, i_maxGaps - 1)
        if array.get(gapFilled, i) == 0
            gDir   = array.get(gapDirs, i)
            gPrice = array.get(gapPrices, i)
            if gDir == 1 and low <= gPrice
                array.set(gapFilled, i, 1)
            if gDir == -1 and high >= gPrice
                array.set(gapFilled, i, 1)

// ─── Visual: Background Color on Gap Days ───
bgColor = isGapUp ? color.new(i_bullColor, 85) : isGapDown ? color.new(i_bearColor, 85) : na
bgcolor(bgColor, title="Gap Day Background")

// ─── Visual: Gap Labels ───
if isGapUp
    labelText = "Gap Up\n" + str.tostring(gapUpPct, "#.##") + "%\n" + gapType
    label.new(bar_index, low, labelText, style=label.style_label_up,
              color=color.new(i_bullColor, 20), textcolor=color.white, size=size.small)

if isGapDown
    labelText = "Gap Down\n" + str.tostring(gapDownPct, "#.##") + "%\n" + gapType
    label.new(bar_index, high, labelText, style=label.style_label_down,
              color=color.new(i_bearColor, 20), textcolor=color.white, size=size.small)

// ─── Visual: Gap Fill Markers ───
if gapUpJustFilled
    label.new(bar_index, low, "Filled", style=label.style_label_up,
              color=color.new(color.orange, 20), textcolor=color.white, size=size.tiny)

if gapDownJustFilled
    label.new(bar_index, high, "Filled", style=label.style_label_down,
              color=color.new(color.orange, 20), textcolor=color.white, size=size.tiny)

// ─── Gap Level Lines ───
plot(not gapUpFilled and not na(gapUpLevel) ? gapUpLevel : na, "Gap Up Level",
     color=color.new(i_bullColor, 40), style=plot.style_linebr, linewidth=1)
plot(not gapDownFilled and not na(gapDownLevel) ? gapDownLevel : na, "Gap Down Level",
     color=color.new(i_bearColor, 40), style=plot.style_linebr, linewidth=1)

// ─── Info Table ───
var table gapTable = table.new(position.bottom_right, 6, i_maxGaps + 1,
                                bgcolor=color.new(color.black, 80),
                                border_width=1, border_color=color.gray)

if barstate.islast and i_showTable and array.size(gapPrices) > 0
    // Headers
    table.cell(gapTable, 0, 0, "#", text_color=color.white, text_size=size.tiny)
    table.cell(gapTable, 1, 0, "Dir", text_color=color.white, text_size=size.tiny)
    table.cell(gapTable, 2, 0, "Price", text_color=color.white, text_size=size.tiny)
    table.cell(gapTable, 3, 0, "Gap %", text_color=color.white, text_size=size.tiny)
    table.cell(gapTable, 4, 0, "Type", text_color=color.white, text_size=size.tiny)
    table.cell(gapTable, 5, 0, "Filled", text_color=color.white, text_size=size.tiny)

    rows = math.min(array.size(gapPrices), i_maxGaps)
    for i = 0 to rows - 1
        dir       = array.get(gapDirs, i)
        dirText   = dir == 1 ? "▲ UP" : "▼ DN"
        dirColor  = dir == 1 ? i_bullColor : i_bearColor
        pct       = array.get(gapPcts, i)
        price     = array.get(gapPrices, i)
        typeCode  = array.get(gapTypes, i)
        typeText  = typeCode == 1 ? "Breakaway" : typeCode == 2 ? "Exhaustion" : "Common"
        filled    = array.get(gapFilled, i)
        fillText  = filled == 1 ? "✓" : "✗"
        fillColor = filled == 1 ? color.green : color.orange

        table.cell(gapTable, 0, i + 1, str.tostring(i + 1), text_color=color.gray, text_size=size.tiny)
        table.cell(gapTable, 1, i + 1, dirText, text_color=dirColor, text_size=size.tiny)
        table.cell(gapTable, 2, i + 1, str.tostring(price, "#.##"), text_color=color.white, text_size=size.tiny)
        table.cell(gapTable, 3, i + 1, str.tostring(pct, "#.##") + "%", text_color=dirColor, text_size=size.tiny)
        table.cell(gapTable, 4, i + 1, typeText, text_color=color.aqua, text_size=size.tiny)
        table.cell(gapTable, 5, i + 1, fillText, text_color=fillColor, text_size=size.tiny)

// ─── Alert Conditions ───
alertcondition(isGapUp, title="Gap Up Detected", message="Gap Scanner: Gap Up {{ticker}} — " + str.tostring(gapUpPct, "#.##") + "%")
alertcondition(isGapDown, title="Gap Down Detected", message="Gap Scanner: Gap Down {{ticker}} — " + str.tostring(gapDownPct, "#.##") + "%")
alertcondition(gapUpJustFilled, title="Gap Up Filled", message="Gap Scanner: Gap Up filled on {{ticker}}")
alertcondition(gapDownJustFilled, title="Gap Down Filled", message="Gap Scanner: Gap Down filled on {{ticker}}")
